{
  "info": {
    "name": "AxisERP - Catalog Service",
    "description": "API endpoints for the Catalog Service (Products & Categories)",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:8082",
      "type": "string"
    },
    {
      "key": "token",
      "value": "",
      "type": "string"
    },
    {
      "key": "productId",
      "value": "",
      "type": "string"
    },
    {
      "key": "categoryId",
      "value": "",
      "type": "string"
    }
  ],
  "item": [
    {
      "name": "Products",
      "item": [
        {
          "name": "Create Product",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Producto de prueba\",\n  \"codigo\": \"PROD-001\",\n  \"categoryId\": \"{{categoryId}}\",\n  \"purchasePrice\": 10.50,\n  \"salePrice\": 15.99\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/v1/productos",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "productos"]
            }
          },
          "response": []
        },
        {
          "name": "Get Product by ID",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/v1/productos/{{productId}}",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "productos", "{{productId}}"]
            }
          },
          "response": []
        },
        {
          "name": "List Products",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/v1/productos?search=&codigo=&categoryId=&includeInactive=false&page=0&size=20",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "productos"],
              "query": [
                {
                  "key": "search",
                  "value": "",
                  "description": "Search by name or code"
                },
                {
                  "key": "codigo",
                  "value": "",
                  "description": "Filter by exact code"
                },
                {
                  "key": "categoryId",
                  "value": "",
                  "description": "Filter by category"
                },
                {
                  "key": "includeInactive",
                  "value": "false",
                  "description": "Include deactivated products"
                },
                {
                  "key": "page",
                  "value": "0",
                  "description": "Page number"
                },
                {
                  "key": "size",
                  "value": "20",
                  "description": "Page size"
                }
              ]
            }
          },
          "response": []
        },
        {
          "name": "Update Product",
          "request": {
            "method": "PUT",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Producto actualizado\",\n  \"categoryId\": \"{{categoryId}}\",\n  \"purchasePrice\": 12.00,\n  \"salePrice\": 18.99\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/v1/productos/{{productId}}",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "productos", "{{productId}}"]
            }
          },
          "response": []
        },
        {
          "name": "Deactivate Product",
          "request": {
            "method": "PATCH",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/v1/productos/{{productId}}/desactivar",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "productos", "{{productId}}", "desactivar"]
            }
          },
          "response": []
        }
      ]
    },
    {
      "name": "Categories",
      "item": [
        {
          "name": "Create Category",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Categoria de prueba\",\n  \"description\": \"Descripcion de la categoria\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/v1/categorias",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "categorias"]
            }
          },
          "response": []
        },
        {
          "name": "List Categories",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/v1/categorias",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "categorias"]
            }
          },
          "response": []
        },
        {
          "name": "Get Category by ID",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/v1/categorias/{{categoryId}}",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "categorias", "{{categoryId}}"]
            }
          },
          "response": []
        },
        {
          "name": "Update Category",
          "request": {
            "method": "PUT",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Categoria actualizada\",\n  \"description\": \"Descripcion actualizada\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/v1/categorias/{{categoryId}}",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "categorias", "{{categoryId}}"]
            }
          },
          "response": []
        },
        {
          "name": "Delete Category",
          "request": {
            "method": "DELETE",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/v1/categorias/{{categoryId}}",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "categorias", "{{categoryId}}"]
            }
          },
          "response": []
        }
      ]
    }
  ]
}
