{
  "name": "AxisERP - Main Branch Protection",
  "target": "branch",
  "enforcement": "active",
  "conditions": {
    "ref_name": {
      "include": [
        "refs/heads/main",
        "refs/heads/master"
      ],
      "exclude": []
    }
  },
  "rules": [
    {
      "type": "pull_request",
      "parameters": {
        "required_approving_review_count": 1,
        "dismiss_stale_reviews_on_push": true,
        "require_code_owner_review": false,
        "require_last_push_approval": true
      }
    },
    {
      "type": "required_status_checks",
      "parameters": {
        "required_status_checks": [
          {
            "context": "Full CI - Build, Docker & Security / ci-auth"
          },
          {
            "context": "Full CI - Build, Docker & Security / ci-catalog"
          },
          {
            "context": "Full CI - Build, Docker & Security / ci-inventory"
          },
          {
            "context": "Full CI - Build, Docker & Security / ci-purchase"
          },
          {
            "context": "Full CI - Build, Docker & Security / ci-sales"
          },
          {
            "context": "Full CI - Build, Docker & Security / ci-report"
          },
          {
            "context": "Full CI - Build, Docker & Security / ci-gateway"
          }
        ],
        "strict_required_status_checks_policy": true
      }
    },
    {
      "type": "non_fast_forward"
    },
    {
      "type": "update",
      "parameters": {
        "update_allows_fetch_and_merge": false
      }
    },
    {
      "type": "deletion"
    },
    {
      "type": "creation"
    }
  ],
  "bypass_actors": []
}
