{
  "info": {
    "_postman_id": "ba1c7695-cdf3-45c2-9f0a-18e6c8cea720",
    "name": "axisERP - Sales Service",
    "description": "Endpoints de ventas, clientes y facturas via API Gateway (puerto 8080). Generado desde codigo fuente.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "Clientes",
      "item": [
        {
          "name": "Create Customer",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"codigo\": \"CLI-000001\",\n  \"name\": \"Maria Garcia\",\n  \"documentType\": \"CC\",\n  \"documentNumber\": \"12345678\",\n  \"email\": \"maria@ejemplo.com\",\n  \"phone\": \"+57 300 1234567\",\n  \"address\": \"Calle 45 #12-30, Bogota\"\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": {
              "raw": "{{baseUrl}}/customers",
              "host": ["{{baseUrl}}"],
              "path": ["customers"]
            },
            "description": "Crear cliente. Roles: ADMIN, VENDEDOR. Codigo formato CLI-000001. DocumentType: CC, NIT, PASAPORTE, CE."
          },
          "response": []
        },
        {
          "name": "List Customers",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/customers?search=&includeInactive=false&page=1&size=20",
              "host": ["{{baseUrl}}"],
              "path": ["customers"],
              "query": [
                { "key": "search", "value": "", "description": "Busqueda por nombre, documento o codigo (CLI-XXXXXX)" },
                { "key": "includeInactive", "value": "false", "description": "Incluir clientes inactivos" },
                { "key": "page", "value": "1" },
                { "key": "size", "value": "20" }
              ]
            },
            "description": "Listar clientes paginados. Roles: ADMIN, VENDEDOR."
          },
          "response": []
        },
        {
          "name": "Get Customer by Codigo",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/customers/{{customerCodigo}}",
              "host": ["{{baseUrl}}"],
              "path": ["customers", "{{customerCodigo}}"]
            },
            "description": "Obtener cliente por codigo de negocio (CLI-000001). Roles: ADMIN, VENDEDOR."
          },
          "response": []
        },
        {
          "name": "Deactivate Customer",
          "request": {
            "method": "PATCH",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/customers/{{customerId}}/deactivate",
              "host": ["{{baseUrl}}"],
              "path": ["customers", "{{customerId}}", "deactivate"]
            },
            "description": "Desactivar cliente por UUID. Solo ADMIN."
          },
          "response": []
        }
      ]
    },
    {
      "name": "Ventas",
      "item": [
        {
          "name": "Create Sale",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"customerId\": \"{{customerId}}\",\n  \"items\": [\n    {\n      \"productId\": \"{{productId}}\",\n      \"quantity\": 2,\n      \"unitPrice\": 250.00,\n      \"discount\": 0\n    }\n  ],\n  \"discount\": 0,\n  \"notes\": \"Venta al contado\"\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": {
              "raw": "{{baseUrl}}/sales",
              "host": ["{{baseUrl}}"],
              "path": ["sales"]
            },
            "description": "Crear venta en estado BORRADOR. Roles: ADMIN, VENDEDOR."
          },
          "response": []
        },
        {
          "name": "List Sales",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/sales?customerId=&status=&page=1&size=20",
              "host": ["{{baseUrl}}"],
              "path": ["sales"],
              "query": [
                { "key": "customerId", "value": "", "description": "Filtrar por UUID de cliente" },
                { "key": "status", "value": "", "description": "Filtrar por estado: BORRADOR, PENDIENTE, CONFIRMADA, PAGADA, ANULADA" },
                { "key": "page", "value": "1" },
                { "key": "size", "value": "20" }
              ]
            },
            "description": "Listar ventas con filtros. Roles: ADMIN, VENDEDOR."
          },
          "response": []
        },
        {
          "name": "Get Sale by ID",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/sales/{{saleId}}",
              "host": ["{{baseUrl}}"],
              "path": ["sales", "{{saleId}}"]
            },
            "description": "Obtener venta por UUID. Roles: ADMIN, VENDEDOR."
          },
          "response": []
        },
        {
          "name": "Confirm Sale",
          "request": {
            "method": "PATCH",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/sales/{{saleId}}/confirm",
              "host": ["{{baseUrl}}"],
              "path": ["sales", "{{saleId}}", "confirm"]
            },
            "description": "Confirmar venta (BORRADOR/PENDIENTE -> CONFIRMADA). Descuenta stock en inventario y genera factura. Roles: ADMIN, VENDEDOR."
          },
          "response": []
        },
        {
          "name": "Pay Sale",
          "request": {
            "method": "PATCH",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/sales/{{saleId}}/pay",
              "host": ["{{baseUrl}}"],
              "path": ["sales", "{{saleId}}", "pay"]
            },
            "description": "Marcar venta como pagada (CONFIRMADA -> PAGADA). Roles: ADMIN, VENDEDOR."
          },
          "response": []
        },
        {
          "name": "Void Sale",
          "request": {
            "method": "PATCH",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/sales/{{saleId}}/void",
              "host": ["{{baseUrl}}"],
              "path": ["sales", "{{saleId}}", "void"]
            },
            "description": "Anular venta (CONFIRMADA/PAGADA -> ANULADA). Devuelve stock al inventario. Solo ADMIN."
          },
          "response": []
        }
      ]
    },
    {
      "name": "Facturas",
      "item": [
        {
          "name": "Get Invoice by ID",
          "request": {
            "method": "GET",
