{
  "info": {
    "_postman_id": "010d52f0-cac9-436d-a39d-75ba0b2c99f8",
    "name": "axisERP - Auth Service",
    "description": "Endpoints de autenticacion y gestion de usuarios. \n\nARQUITECTURA:\n- El LOGIN se hace DIRECTAMENTE a Supabase Auth REST API (NO pasa por el gateway)\n- Los demas endpoints van via API Gateway (puerto 8080)\n- Supabase retorna un access_token JWT que se usa como Bearer token\n\nFLUJO: \n1. Ejecutar \"Obtener Token Supabase\" -> copia el access_token a la variable authToken\n2. Usar los demas endpoints (automaticamente usan el token)",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "Supabase Auth (directo a Supabase)",
      "item": [
        {
          "name": "Obtener Token Supabase",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "var jsonData = pm.response.json();",
                  "if (jsonData.access_token) {",
                  "    pm.collectionVariables.set('authToken', jsonData.access_token);",
                  "    pm.collectionVariables.set('refreshToken', jsonData.refresh_token);",
                  "    console.log('Token obtenido: ' + jsonData.access_token.substring(0, 20) + '...');",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "apikey", "value": "{{supabaseAnonKey}}", "type": "text" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"santiagoalvarez374@gmail.com\",\n  \"password\": \"Santiabad*123\",\n  \"gotrue_meta_security\": {}\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": {
              "raw": "{{supabaseUrl}}/auth/v1/token?grant_type=password",
              "host": ["{{supabaseUrl}}"],
              "path": ["auth", "v1", "token"],
              "query": [{ "key": "grant_type", "value": "password" }]
            },
            "description": "Autenticar contra Supabase Auth. Retorna access_token JWT que se usa para todos los demas endpoints. Este endpoint NO pasa por el gateway."
          },
          "response": []
        },
        {
          "name": "Registrar Usuario (Signup)",
          "request": {
            "method": "POST",
            "header": [
              { "key": "apikey", "value": "{{supabaseAnonKey}}", "type": "text" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"nuevo@axiserp.com\",\n  \"password\": \"Password*123\"\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": {
              "raw": "{{supabaseUrl}}/auth/v1/signup",
              "host": ["{{supabaseUrl}}"],
              "path": ["auth", "v1", "signup"]
            },
            "description": "Registrar nuevo usuario en Supabase. Recibe email de confirmacion."
          },
          "response": []
        }
      ]
    },
    {
      "name": "Auth - Autenticado (via Gateway)",
      "item": [
        {
          "name": "Get My Info",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/auth/me",
              "host": ["{{baseUrl}}"],
              "path": ["auth", "me"]
            },
            "description": "Obtener informacion del usuario autenticado desde el JWT. Cualquier rol."
          },
          "response": []
        },
        {
          "name": "Password Reset (delega a Supabase)",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"santiagoalvarez374@gmail.com\"\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": {
              "raw": "{{baseUrl}}/auth/password-reset",
              "host": ["{{baseUrl}}"],
              "path": ["auth", "password-reset"]
            },
            "description": "Solicitar email de recuperacion. Siempre retorna 200 (no revela si el email existe - OWASP A07). NO requiere token."
          },
          "response": []
        }
      ]
    },
    {
      "name": "Usuarios (ADMIN, via Gateway)",
      "item": [
        {
          "name": "Create User",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Juan Perez\",\n  \"email\": \"juan@axiserp.com\",\n  \"role\": \"VENDEDOR\"\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": {
              "raw": "{{baseUrl}}/usuarios",
              "host": ["{{baseUrl}}"],
              "path": ["usuarios"]
            },
            "description": "Crear usuario en Supabase + perfil local. Solo ADMIN. Roles: ADMIN, VENDEDOR, INVENTARIO. El usuario recibe email de invitacion."
          },
          "response": []
        },
        {
          "name": "List Users",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/usuarios",
              "host": ["{{baseUrl}}"],
              "path": ["usuarios"]
            },
            "description": "Listar todos los usuarios. Solo ADMIN."
          },
          "response": []
        },
        {
          "name": "Get User by ID",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/usuarios/{{userId}}",
              "host": ["{{baseUrl}}"],
              "path": ["usuarios", "{{userId}}"]
            },
            "description": "Obtener usuario por UUID. Solo ADMIN."
          },
          "response": []
        },
        {
          "name": "Update User",
          "request": {
            "method": "PUT",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Juan Perez Actualizado\",\n  \"email\": \"juan.nuevo@axiserp.com\",\n  \"role\": \"VENDEDOR\"\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": {
              "raw": "{{baseUrl}}/usuarios/{{userId}}",
              "host": ["{{baseUrl}}"],
              "path": ["usuarios", "{{userId}}"]
            },
            "description": "Actualizar nombre, email y/o rol. Solo ADMIN."
          },
          "response": []
        },
        {
          "name": "Deactivate User",
          "request": {
            "method": "PATCH",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/usuarios/{{userId}}/desactivar",
              "host": ["{{baseUrl}}"],
              "path": ["usuarios", "{{userId}}", "desactivar"]
            },
            "description": "Desactivar usuario (soft delete, status -> INACTIVO). Solo ADMIN."
          },
          "response": []
        },
        {
          "name": "Get My Profile",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/usuarios/me",
              "host": ["{{baseUrl}}"],
              "path": ["usuarios", "me"]
            },
            "description": "Obtener perfil extendido del usuario autenticado. Cualquier rol."
          },
          "response": []
        }
      ]
    },
    {
      "name": "Audit Log (ADMIN, via Gateway)",
      "item": [
        {
          "name": "Get Audit Logs",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/audit-log?userId=&action=&entityType=&page=0&size=20",
              "host": ["{{baseUrl}}"],
              "path": ["audit-log"],
              "query": [
                { "key": "userId", "value": "", "description": "Filtrar por UUID de usuario" },
                { "key": "action", "value": "", "description": "Filtrar por accion (CREATE, UPDATE, DEACTIVATE)" },
                { "key": "entityType", "value": "", "description": "Filtrar por tipo de entidad (USER)" },
                { "key": "page", "value": "0" },
                { "key": "size", "value": "20" }
              ]
            },
            "description": "Historial de auditoria. Solo ADMIN."
          },
          "response": []
        }
      ]
    }
  ],
  "auth": {
    "type": "bearer",
    "bearer": [{ "key": "token", "value": "{{authToken}}", "type": "string" }]
  },
  "variable": [
    { "key": "baseUrl", "value": "http://localhost:8080/api/v1" },
    { "key": "supabaseUrl", "value": "https://hbtcusxbkkefphunarwn.supabase.co" },
    { "key": "supabaseAnonKey", "value": "eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZSIsInJlZiI6ImhidGN1c3hia2tlZnBodW5hcnduIiwicm9sZSI6ImFub24iLCJpYXQiOjE3NzgzNzUyNTYsImV4cCI6MjA5Mzk1MTI1Nn0.FpKfLdzSlHBOtW4gpVFzxtzGAyfxWfcniWnEdwV63rw" },
    { "key": "authToken", "value": "" },
    { "key": "refreshToken", "value": "" },
    { "key": "userId", "value": "" }
  ]
}
