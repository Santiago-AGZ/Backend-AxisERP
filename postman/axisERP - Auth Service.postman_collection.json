              "options": { "raw": { "language": "json" } }
            },
            "url": {
              "raw": "{{baseUrl}}/usuarios/{{userId}}",
              "host": ["{{baseUrl}}"],
              "path": ["usuarios", "{{userId}}"]
            },
            "description": "Actualizar nombre, email y/o rol. Solo ADMIN."
