{
  "info": {
    "_postman_id": "010d52f0-cac9-436d-a39d-75ba0b2c99f8",
    "name": "axisERP - Auth Service",
    "description": "Endpoints de autenticacion y gestion de usuarios via API Gateway (puerto 8080). Generado desde codigo fuente.",
