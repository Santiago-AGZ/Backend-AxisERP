            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Juan Perez\",\n  \"email\": \"juan@axiserp.com\",\n  \"password\": \"Password*123\",\n  \"role\": \"VENDEDOR\"\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": {
              "raw": "{{baseUrl}}/usuarios",
              "host": ["{{baseUrl}}"],
              "path": ["usuarios"]
            },
            "description": "Crear usuario. Solo ADMIN. Roles validos: ADMIN, VENDEDOR, INVENTARIO."
          },
          "response": []
        },
        {
          "name": "List Users",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/usuarios",
              "host": ["{{baseUrl}}"],
              "path": ["usuarios"]
            },
            "description": "Listar todos los usuarios. Solo ADMIN."
