{
  "info": {
    "_postman_id": "346f28e4-4883-4293-b8c3-bbc5ccacb535",
    "name": "axisERP - Purchase Service",
    "description": "Endpoints de proveedores y compras via API Gateway (puerto 8080).\n\nFLUJO:\n1. Obtener authToken desde Auth Service\n2. Copiar authToken\n3. Crear proveedor (auto-setea supplierId)\n4. Crear compra con items (incluye productName)\n\nREGLAS: R1-R22 (proveedores + compras), SupplierStatus=ACTIVO/INACTIVO/ELIMINADO",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "Proveedores",
      "item": [
        {
          "name": "Create Supplier",
          "event": [{
            "listen": "test",
            "script": { "exec": ["var d = pm.response.json(); if(d.success && d.data) { pm.collectionVariables.set('supplierId', d.data.id); pm.collectionVariables.set('supplierCodigo', d.data.codigo); console.log('Supplier: ' + d.data.codigo); }"], "type": "text/javascript" }
          }],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"codigo\": \"PROV-000001\",\n  \"name\": \"Distribuidora ABC SAS\",\n  \"nit\": \"900123456-1\",\n  \"phone\": \"+57 1 2345678\",\n  \"email\": \"contacto@abc.com\",\n  \"address\": \"Cra 30 #45-12, Bogota\"\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": { "raw": "{{baseUrl}}/suppliers", "host": ["{{baseUrl}}"], "path": ["suppliers"] },
            "description": "Crear proveedor. Auto-setea supplierId y supplierCodigo. Roles: ADMIN, INVENTARIO."
          },
          "response": []
        },
        {
          "name": "List Suppliers",
          "request": {
            "method": "GET", "header": [],
            "url": {
              "raw": "{{baseUrl}}/suppliers?search=&page=1&size=20",
              "host": ["{{baseUrl}}"], "path": ["suppliers"],
              "query": [
                { "key": "search", "value": "", "description": "Buscar por nombre, codigo o NIT" },
                { "key": "page", "value": "1" },
                { "key": "size", "value": "20" }
              ]
            },
            "description": "Listar proveedores con filtro search (nombre, codigo, NIT) y paginacion."
          },
          "response": []
        },
        {
          "name": "Get Supplier by ID",
          "request": {
            "method": "GET", "header": [],
            "url": { "raw": "{{baseUrl}}/suppliers/{{supplierId}}", "host": ["{{baseUrl}}"], "path": ["suppliers", "{{supplierId}}"] }
          },
          "response": []
        },
        {
          "name": "Deactivate Supplier",
          "request": {
            "method": "PATCH", "header": [],
            "url": { "raw": "{{baseUrl}}/suppliers/{{supplierId}}/deactivate", "host": ["{{baseUrl}}"], "path": ["suppliers", "{{supplierId}}", "deactivate"] },
            "description": "Desactivar proveedor (soft-delete -> ELIMINADO). Roles: ADMIN."
          },
          "response": []
        }
      ]
    },
    {
      "name": "Compras",
      "item": [
        {
          "name": "Create Purchase",
          "event": [{
            "listen": "test",
            "script": { "exec": ["var d = pm.response.json(); if(d.success && d.data) { pm.collectionVariables.set('purchaseId', d.data.id); console.log('Purchase: ' + d.data.purchaseNumber); }"], "type": "text/javascript" }
          }],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"supplierId\": \"{{supplierId}}\",\n  \"items\": [\n    {\n      \"productId\": \"{{productId}}\",\n      \"productName\": \"Monitor Samsung 27 pulgadas\",\n      \"quantity\": 10,\n      \"unitPrice\": 150.00\n    }\n  ],\n  \"notes\": \"Orden de compra mensual\"\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": { "raw": "{{baseUrl}}/purchases", "host": ["{{baseUrl}}"], "path": ["purchases"] },
            "description": "Crear compra con items. productName es obligatorio. Auto-setea purchaseId. Roles: ADMIN, INVENTARIO."
          },
          "response": []
        },
        {
          "name": "List Purchases",
          "request": {
            "method": "GET", "header": [],
            "url": {
              "raw": "{{baseUrl}}/purchases?search=&status=&page=1&size=20",
              "host": ["{{baseUrl}}"], "path": ["purchases"],
              "query": [
                { "key": "search", "value": "", "description": "Buscar por numero de compra" },
                { "key": "status", "value": "", "description": "BORRADOR|PENDIENTE|RECIBIDA|PAGADA|CANCELADA" },
                { "key": "page", "value": "1" },
                { "key": "size", "value": "20" }
              ]
            },
            "description": "Listar compras con filtros y paginacion."
          },
          "response": []
        },
        {
          "name": "Get Purchase by ID",
          "request": {
            "method": "GET", "header": [],
            "url": { "raw": "{{baseUrl}}/purchases/{{purchaseId}}", "host": ["{{baseUrl}}"], "path": ["purchases", "{{purchaseId}}"] }
          },
          "response": []
        },
        {
          "name": "Cancel Purchase",
          "request": {
            "method": "PATCH", "header": [],
            "url": { "raw": "{{baseUrl}}/purchases/{{purchaseId}}/cancel", "host": ["{{baseUrl}}"], "path": ["purchases", "{{purchaseId}}", "cancel"] },
            "description": "Cancelar compra. Revierte movimientos de inventario si tenia items recibidos. Roles: ADMIN."
          },
          "response": []
        }
      ]
    }
  ],
  "auth": {
    "type": "bearer",
    "bearer": [{ "key": "token", "value": "{{authToken}}", "type": "string" }]
  },
  "variable": [
    { "key": "baseUrl", "value": "http://localhost:8080/api/v1" },
    { "key": "authToken", "value": "" },
    { "key": "supplierId", "value": "" },
    { "key": "supplierCodigo", "value": "" },
    { "key": "purchaseId", "value": "" },
    { "key": "productId", "value": "" }
  ]
}