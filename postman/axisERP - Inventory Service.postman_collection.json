{
  "info": {
    "_postman_id": "ce987e20-2d40-4837-8b21-86c61d72c936",
    "name": "axisERP - Inventory Service",
    "description": "Endpoints de inventario via API Gateway (puerto 8080).\n\nFLUJO:\n1. Obtener authToken desde la coleccion Auth Service\n2. Copiar authToken a esta coleccion\n3. Inicializar inventario del producto (POST /initialize)\n4. Operar: entry/exit/adjust/return/reverse\n\nREGLAS IMPLEMENTADAS:\n- R1: Unico registro por producto (initialize)\n- R2-R5: Stock >= 0, max > min (validacion + DB constraints)\n- R6: Inicial solo una vez\n- R7: Entradas aumentan stock\n- R8: Salidas disminuyen stock\n- R9: Salidas no exceden disponible (InsufficientStockException)\n- R10: Cantidad > 0 (NegativeQuantityException)\n- R11: Movimiento registra anterior/nuevo/usuario/fecha\n- R12: Tipos validos (INVENTARIO_INICIAL, ENTRADA, SALIDA, AJUSTE_POSITIVO/NEGATIVO, DEVOLUCION, ANULACION)\n- R13: Ajustes requieren justificacion\n- R14: Anulaciones generan movimiento de reversion\n- R15: Historicos no se modifican\n- R16: Alertas stock bajo (isLowStock)\n- R17: Alertas agotamiento (isDepleted)\n- R18-R19: Control concurrencia con @Version\n- R20: Auditoria (STOCK_ENTRY, STOCK_EXIT, REVERSAL, CREATE)\n\nRESPUESTA: ApiResponse<T> con success/code/data/message/meta/pagination. Null values ocultos via @JsonInclude(NON_NULL).",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "Inicializacion",
      "item": [
        {
          "name": "Initialize Inventory",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"productId\": \"{{productId}}\",\n  \"initialStock\": 100,\n  \"minStock\": 10,\n  \"maxStock\": 500,\n  \"notes\": \"Stock inicial cargado\"\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": {
              "raw": "{{baseUrl}}/inventory/initialize",
              "host": ["{{baseUrl}}"],
              "path": ["inventory", "initialize"]
            },
            "description": "Inicializar registro de inventario para un producto. Se llama una sola vez por producto. Roles: ADMIN, INVENTARIO."
          },
          "response": []
        }
      ]
    },
    {
      "name": "Consultas",
      "item": [
        {
          "name": "Get Inventory by Product",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/inventory/products/{{productId}}",
              "host": ["{{baseUrl}}"],
              "path": ["inventory", "products", "{{productId}}"]
            },
            "description": "Obtener estado de inventario de un producto por UUID. Todos los roles autenticados."
          },
          "response": []
        },
        {
          "name": "List Movements by Product",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/inventory/products/{{productId}}/movements",
              "host": ["{{baseUrl}}"],
              "path": ["inventory", "products", "{{productId}}", "movements"]
            },
            "description": "Historial de movimientos de un producto. Todos los roles autenticados."
          },
          "response": []
        }
      ]
    },
    {
      "name": "Movimientos",
      "item": [
        {
          "name": "Register Entry (Entrada)",
          "request": {
            "method": "POST",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/inventory/products/{{productId}}/entry?quantity=50&referenceType=COMPRA&referenceId={{purchaseId}}&notes=Recepcion+de+compra",
              "host": ["{{baseUrl}}"],
              "path": ["inventory", "products", "{{productId}}", "entry"],
              "query": [
                { "key": "quantity", "value": "50", "description": "Cantidad a ingresar (obligatorio)" },
                { "key": "referenceType", "value": "COMPRA", "description": "Tipo de referencia (COMPRA, AJUSTE, etc.)" },
                { "key": "referenceId", "value": "{{purchaseId}}", "description": "UUID del documento de referencia (opcional)" },
                { "key": "notes", "value": "Recepcion de compra", "description": "Notas del movimiento (opcional)" }
              ]
            },
            "description": "Registrar entrada de stock (incrementa stock). Roles: ADMIN, INVENTARIO."
          },
          "response": []
        },
        {
          "name": "Register Exit (Salida)",
          "request": {
            "method": "POST",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/inventory/products/{{productId}}/exit?quantity=10&referenceType=VENTA&referenceId={{saleId}}&notes=Salida+por+venta",
              "host": ["{{baseUrl}}"],
              "path": ["inventory", "products", "{{productId}}", "exit"],
              "query": [
                { "key": "quantity", "value": "10", "description": "Cantidad a descontar (obligatorio)" },
                { "key": "referenceType", "value": "VENTA", "description": "Tipo de referencia" },
                { "key": "referenceId", "value": "{{saleId}}", "description": "UUID del documento de referencia (opcional)" },
                { "key": "notes", "value": "Salida por venta", "description": "Notas del movimiento (opcional)" }
              ]
            },
            "description": "Registrar salida de stock (decrementa stock). Falla con 409 si stock insuficiente. Roles: ADMIN, INVENTARIO."
          },
          "response": []
        },
        {
          "name": "Register Return (Devolucion)",
          "request": {
            "method": "POST",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/inventory/products/{{productId}}/return?quantity=5&referenceType=VENTA&referenceId={{saleId}}&notes=Devolucion+por+anulacion",
              "host": ["{{baseUrl}}"],
              "path": ["inventory", "products", "{{productId}}", "return"],
              "query": [
                { "key": "quantity", "value": "5", "description": "Cantidad a devolver" },
                { "key": "referenceType", "value": "VENTA", "description": "Tipo de referencia" },
                { "key": "referenceId", "value": "{{saleId}}", "description": "UUID de referencia (opcional)" },
                { "key": "notes", "value": "Devolucion por anulacion", "description": "Notas (opcional)" }
              ]
            },
            "description": "Registrar devolucion de stock (incrementa stock). Roles: ADMIN, INVENTARIO."
          },
          "response": []
        },
        {
          "name": "Register Adjustment (Ajuste)",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"adjustmentType\": \"POSITIVO\",\n  \"quantity\": 5,\n  \"justification\": \"Conteo fisico diferente al registrado\",\n  \"notes\": \"Ajuste de fin de mes\"\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": {
              "raw": "{{baseUrl}}/inventory/products/{{productId}}/adjust",
              "host": ["{{baseUrl}}"],
              "path": ["inventory", "products", "{{productId}}", "adjust"]
            },
            "description": "Ajuste manual de inventario. adjustmentType: POSITIVO (suma) o NEGATIVO (resta). Roles: ADMIN, INVENTARIO."
          },
          "response": []
        },
        {
          "name": "Reverse Movement",
          "request": {
            "method": "POST",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/inventory/movements/{{movementId}}/reverse?justification=Reversion+por+error",
              "host": ["{{baseUrl}}"],
              "path": ["inventory", "movements", "{{movementId}}", "reverse"],
              "query": [
                { "key": "justification", "value": "Reversion por error", "description": "Motivo de la reversion (obligatorio)" }
              ]
            },
            "description": "Revertir un movimiento de inventario por UUID de movimiento. Roles: ADMIN, INVENTARIO."
          },
          "response": []
        }
      ]
    }
  ],
  "auth": {
    "type": "bearer",
    "bearer": [{ "key": "token", "value": "{{authToken}}", "type": "string" }]
  },
  "variable": [
    { "key": "baseUrl", "value": "http://localhost:8080/api/v1" },
    { "key": "authToken", "value": "" },
    { "key": "productId", "value": "" },
    { "key": "movementId", "value": "" },
    { "key": "purchaseId", "value": "" },
    { "key": "saleId", "value": "" }
  ]
}
