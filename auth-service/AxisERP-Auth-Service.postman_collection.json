              "}"
            ],
            "type": "text/javascript"
          }
        }
      ]
    },
    {
      "name": "HU-034 - Acceso Protegido (/me)",
      "request": {
        "method": "GET",
        "header": [
          { "key": "Authorization", "value": "Bearer {{access_token}}" }
        ],
        "url": {
          "raw": "{{base_url}}/api/v1/auth/me",
          "host": ["{{base_url}}"],
          "path": ["api", "v1", "auth", "me"]
        }
      }
    },
    {
      "name": "HU-034 - Acceso Sin Token (401)",
      "request": {
