          "mode": "raw",
          "raw": "{\n  \"name\": \"Nuevo Usuario\",\n  \"email\": \"nuevo@axiserp.com\",\n  \"password\": \"Test@1234\",\n  \"role\": \"VENDEDOR\"\n}"
