    {
      "name": "HU-001 - Refresh Token",
      "request": {
        "method": "POST",
        "header": [
          { "key": "Content-Type", "value": "application/json" }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"refreshToken\": \"{{refresh_token}}\"\n}"
        },
        "url": {
          "raw": "{{base_url}}/api/v1/auth/refresh",
          "host": ["{{base_url}}"],
          "path": ["api", "v1", "auth", "refresh"]
        }
